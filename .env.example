# harvester-helm-harbor-sync configuration
# Copy to .env and customize for your environment:  cp .env.example .env

# === Domain ===
# Base domain for all proxy hostnames (yum.DOMAIN, apt.DOMAIN, etc.)
DOMAIN=example.com

# === Harbor Registry (external) ===
# Harbor instance where helm-sync pushes OCI chart artifacts
HARBOR_HOST=harbor.example.com
HARBOR_USER=robot$helm-sync
HARBOR_PASS=changeme

# === Proxy VM ===
# Static IP for the proxy VM (used by setup-proxy-vm.sh)
PROXY_VM_IP=10.0.0.100
SSH_USER=rocky

# === Certificate Generation ===
# PKI directory containing root CA cert and key
PKI_DIR=./pki
CERT_ORG="Example Org"
